# ── Server ────────────────────────────────────────────────────────────────────
BACKEND_PORT=4000

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Docker: mongodb://mongo:27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=shop_keeper

# ── Security ──────────────────────────────────────────────────────────────────
# Strong random secret for JWT signing — CHANGE THIS in production!
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=changeme-use-a-strong-secret-in-production
JWT_EXPIRES_IN=7d

# Optional API key required on all /api/sync/* requests (leave empty to disable)
SYNC_API_KEY=dummy_sync_api_key_for_production

# Optional: set to false to block remote deletes through sync API (default is enabled)
ENABLE_REMOTE_SYNC_DELETE=true

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
FRONTEND_ORIGIN=https://swiftpos-iota.vercel.app/
